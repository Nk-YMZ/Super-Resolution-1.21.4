    "superresolution.screen.config.options.tooltip.enable_upscale": "When enabled, uses the selected algorithm to super resolve the image",
    "superresolution.screen.config.options.tooltip.force_disable_shader_compat": "When enabled, the mod will ignore the shader pack's super resolution compatibility profile and perform scaling in normal mode",
    "superresolution.screen.config.options.tooltip.generate_motion_vectors": "Motion vectors can improve the super resolution quality of some algorithms (FSR2, SGSR2), but will cost performance (deprecated)",
    "superresolution.screen.config.options.tooltip.inject_postChain_black_list": "Some mods use PostChain for UI effects.\nInjecting code into PostChain by this mod will cause UI effects to render at world resolution, causing rendering issues (e.g., blurred ModernUI interface).\nAdd the names of PostChains you wish to exclude here, and the mod will skip them.\nChanges may require a game restart to take effect.",
    "superresolution.screen.config.options.tooltip.internal_texture_format": "The precision of the internal texture format affects VRAM usage: higher precision means higher usage; lower precision means lower usage.\nNote: Too low precision may cause visible color banding.",
    "superresolution.screen.config.options.tooltip.interop_sync_mode": "The mod uses OpenGL-Vulkan interop for super resolution (only for some algorithms, like DLSS). Interop sync mode determines how the mod synchronizes resources between OpenGL and Vulkan.\nLow Latency mode processes the current frame directly, synchronizing OpenGL and Vulkan, resulting in lower latency but may reduce low frame rates.\nPerformance mode allows super resolution on Vulkan to run concurrently with game rendering on OpenGL, improving performance but increasing input lag. This mode is unstable and offers minor gains.",
    "superresolution.screen.config.options.tooltip.sharpness": "Lower values make edges more distinct\nHigher values make distant objects blurrier\nRecommended value: around 0.55",
    "superresolution.screen.config.options.tooltip.skip_init_vulkan": "Skipping Vulkan initialization may affect some algorithms.",
    "superresolution.screen.config.options.tooltip.skip_load_native_lib": "Skipping native library loading may cause malfunctions.",
    "superresolution.screen.config.options.tooltip.theme_contrast_level": "Adjust the contrast of the UI color scheme (-1 = lowest, 0 = standard, 1 = highest)",
    "superresolution.screen.config.options.tooltip.upscale_ratio": "Higher values mean lower rendering resolution, blurrier image, and lower performance cost.\nLower values mean higher rendering resolution, sharper image, and higher performance cost.\nCurrent rendering resolution: %sx%s\nCurrent rendering precision: %s\nRecommended value: 1.4~1.8",
